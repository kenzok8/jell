msgstr "Povolit hromadné zprávy"

msgid "This option allows you to send one message to all contacts in the user's contact list."
msgstr "Tato možnost umožňuje odeslat jednu zprávu všem kontaktům v seznamu kontaktů uživatele."

msgid "Message sending delay"
msgstr "Zpoždění odesílání zpráv"

