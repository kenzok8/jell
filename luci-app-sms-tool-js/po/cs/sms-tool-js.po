msgid "User interface for reading messages using sms-tool. More information about the sms-tool on the %seko.one.pl forum%s."
msgstr "Uživatelské rozhraní pro čtení zpráv pomocí nástroje sms-tool. Více informací o sms-tool naleznete na %sfóru eko.one.pl%s."

msgid "User interface for sending messages using sms-tool. More information about the sms-tool on the %seko.one.pl forum%s."
msgstr "Uživatelské rozhraní pro odesílání zpráv pomocí nástroje sms-tool. Více informací o sms-tool naleznete na %sfóru eko.one.pl%s."

msgid "User interface for sending AT commands using sms-tool. More information about the sms-tool on the %seko.one.pl forum%s."
msgstr "Uživatelské rozhraní pro odesílání AT příkazů pomocí nástroje sms-tool. Více informací o sms-tool naleznete na %sfóru eko.one.pl%s."

msgid "User interface for sending USSD codes using sms-tool. More information about the sms-tool on the %seko.one.pl forum%s."
msgstr "Uživatelské rozhraní pro odesílání USSD kódů pomocí nástroje sms-tool. Více informací o sms-tool naleznete na %sfóru eko.one.pl%s."

msgid "Configuration sms-tool"
msgstr "Konfigurace sms-tool"

msgid "Configuration panel for sms-tool and gui application."
msgstr "Konfigurační panel pro sms-tool a grafické rozhraní."

msgid "Port for communication with the modem"
msgstr "Port pro komunikaci s modemem"

