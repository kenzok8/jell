msgid "Each line must have the following format: 'Contact name;phone number'. For user convenience, the file is saved to the location <code>/etc/modem/phonebook.user</code>."
msgstr "Cada linha deve ter o seguinte formato: 'Nome do contato;número de telefone'. Para conveniência do usuário, o arquivo é salvo no local <code>/etc/modem/phonebook.user</code>."

msgid "Press [Enter] to send the command, press [Delete] to delete the command"
msgstr "Pressione [Enter] para enviar o comando, pressione [Delete] para excluir o comando"

msgid "Press [Enter] to send the code, press [Delete] to delete the code"
msgstr "Pressione [Enter] para enviar o código, pressione [Delete] para excluir o código"

