msgid "PowerOff"
msgstr "关机"

msgid "⚠️ PowerOff Device"
msgstr "⚠️ 设备关机"

msgid "⚠️ Perform Power Off"
msgstr "⚠️ 执行关机"

msgid "Turn off the power to the device you are using"
msgstr "关闭您正在使用的设备的电源"

msgid "This action will immediately turn off the power to your device. Make sure to save all your work before proceeding."
msgstr "此操作将立即关闭设备的电源。在继续之前，请确保保存所有工作" 

msgid "Powering off device..."
msgstr "正在关机..."

msgid "Confirm Power Off"
msgstr "确认关机"

msgid "Warning!"
msgstr "警告"

msgid "Before you continue:"
msgstr "继续关机之前："

msgid "Save all unsaved settings"
msgstr "保存所有未保存的设置"

msgid "Check if other users are active"
msgstr "检查其他用户是否处于活动状态"

msgid "The device needs to be manually turned on"
msgstr "设备需要手动开机"

msgid "Powering Off"
msgstr "关机中"

msgid "The device should power off within a few seconds. If the device remains on, you may need to perform a manual shutdown."
msgstr "设备应在几秒钟内关闭。如果设备保持开启状态，您可能需要执行手动关机"



