{
    "luci-app-pppoe-user": {
        "description": "Grant access to pppoe-user",
        "read": {
            "uci": [ "pppoe-user" ],
            "file": {
                "/var/etc/pppoe-user/session/*.json": [ "read" ],
                "/var/pppoe-user/log/interface.log": [ "read" ],
                "/proc/net/dev": [ "read" ]
            }
        },
        "write": {
            "uci": [ "pppoe-user" ],
            "exec": {
                "/bin/kill": [ "arg1" ],
                "/usr/bin/unlink": [ "arg1" ] 
            }
        }
    }
}
